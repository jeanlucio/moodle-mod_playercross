{{!
    @template mod_playercross/lobby

    Pre-round lobby, shown before the player starts the timer for a ready round.

    Example context (json):
    {
        "cluesthisround": "5 clues this round.",
        "timerenabled": true,
        "lobbytimerinfo": "You have 1 min to solve the puzzle.",
        "hudstartcost": true,
        "hudstartcostlabel": "You have 0× Gold Key. Costs 1× Gold Key.",
        "canstart": false,
        "startlabel": "Start round",
        "showgradingmethodinfo": true,
        "gradingmethodinfo": "Grading method: Average grade",
        "roundsplayedlabel": "Rounds played: 0 / 10."
    }
}}
<div id="playercross-lobby-body" class="mod-playercross-lobby text-center my-3">
    <p class="text-muted">{{cluesthisround}}</p>
    {{#timerenabled}}
        <p class="text-muted">{{lobbytimerinfo}}</p>
    {{/timerenabled}}
    {{#roundsplayedlabel}}
        <p class="text-muted small">{{roundsplayedlabel}}</p>
    {{/roundsplayedlabel}}
    {{#hudstartcost}}
        <p class="mb-2">{{hudstartcostlabel}}</p>
    {{/hudstartcost}}
    {{#showgradingmethodinfo}}
        <p class="text-muted small">{{gradingmethodinfo}}</p>
    {{/showgradingmethodinfo}}
    <button type="button"
            id="playercross-start-round-button"
            class="btn btn-primary btn-lg"
            {{^canstart}}disabled{{/canstart}}>{{startlabel}}</button>
</div>
