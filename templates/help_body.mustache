{{!
    @template mod_playercross/help_body

    How-to-play help content for a PlayerCross activity, shown inside a modal
    opened from the in-game toolbar (see amd/src/game.js).

    Example context (json):
    {
        "introtext": "Solve clues about course concepts. Each correct answer reveals shared letters of the mystery phrase.",
        "legendrevealedlabel": "Revealed: this letter is known.",
        "legendhiddenlabel": "Hidden: this letter is not known yet.",
        "cluestext": "Each clue is a separate word; guess it in the box next to it.",
        "hinttext": "A hint may be available for each clue, depending on how the teacher configured the activity.",
        "finalguesstext": "You can guess the mystery phrase directly at any time, even with clues still pending.",
        "winconditiontext": "To win a round, you must resolve every clue and correctly guess the mystery phrase.",
        "showclueloss": true,
        "cluelosstext": "Each clue has a limited number of attempts. If one runs out, winning becomes impossible and the round ends immediately as a loss.",
        "timertext": "Some activities have a time limit per round.",
        "showhud": true,
        "hudtext": "This activity may require PlayerHUD items to start a round or reveal a hint, and can reward you with an item for winning a round.",
        "showgrading": true,
        "gradingtext": "Grading method: Highest grade.",
        "reviewhint": "You can review these instructions anytime by clicking the help icon at the top of the game."
    }
}}
<div class="mod-playercross-help-body">
    <p>{{introtext}}</p>
    <ul class="mod-playercross-help-legend">
        <li><span class="pc-legend-swatch is-revealed" aria-hidden="true">A</span> {{legendrevealedlabel}}</li>
        <li><span class="pc-legend-swatch is-hidden" aria-hidden="true">A</span> {{legendhiddenlabel}}</li>
    </ul>
    <p>{{cluestext}}</p>
    <p>{{hinttext}}</p>
    <p>{{finalguesstext}}</p>
    <p>{{winconditiontext}}</p>
    {{#showclueloss}}
        <p>{{cluelosstext}}</p>
    {{/showclueloss}}
    <p>{{timertext}}</p>
    {{#showhud}}
        <p>{{hudtext}}</p>
    {{/showhud}}
    {{#showgrading}}
        <p>{{gradingtext}}</p>
    {{/showgrading}}
    <p>{{reviewhint}}</p>
</div>
