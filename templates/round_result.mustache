{{!
    @template mod_playercross/round_result

    Post-round panel: feedback message, mystery-phrase reveal, a recap of every clue's
    own hint and answer word (reusing the 'clues' context round_presenter::
    build_round_panel_context() already builds via build_clue_rows() for round_play —
    every clue's own revealword is populated once the round is finished, regardless of
    whether the student actually resolved it), score, cooldown countdown and the
    new-round action.

    Example context (json):
    {
        "feedbackmessage": "You solved the mystery phrase!",
        "revealthemewordlabel": "The mystery phrase was:",
        "revealthemeword": "ESCOLA",
        "resultclueslabel": "Clues from this round:",
        "clues": [
            {
                "clueid": 12,
                "phrase": "A tool used to write",
                "resolved": true,
                "revealword": "CANETA"
            },
            {
                "clueid": 13,
                "phrase": "A place to keep notes and school exercises",
                "resolved": false,
                "revealword": "CADERNO"
            }
        ],
        "scoreachievedlabel": "Score achieved:",
        "scoreachieved": "85.00",
        "cooldowntext": "23h 59m 45s",
        "cooldowncountdownlabel": "Next round in",
        "cooldownactive": false,
        "newroundlabel": "Start a new round",
        "showgradesofar": true,
        "gradesofarmessage": "Average grade: 6.50 / 10.00.",
        "roundsplayedlabel": "Rounds played: 3 / 10.",
        "huditemrewardedlabel": "You received 1× Gold Key!"
    }
}}
<div id="playercross-round-result" tabindex="-1">
    {{#feedbackmessage}}
        <p class="mod-playercross-feedback fw-bold mt-3 text-center">{{feedbackmessage}}</p>
    {{/feedbackmessage}}
    <div class="mod-playercross-reveal alert alert-secondary mt-3 text-center">
        <p class="mb-1"><strong>{{revealthemewordlabel}}</strong> {{revealthemeword}}</p>
        <p class="mb-0">{{scoreachievedlabel}} {{scoreachieved}}</p>
    </div>
    <p class="fw-bold text-center mt-3 mb-2">{{resultclueslabel}}</p>
    <ul class="mod-playercross-clues list-unstyled">
        {{#clues}}
            <li class="mod-playercross-clue{{#resolved}} is-resolved{{/resolved}}">
                <p class="mod-playercross-clue-phrase">{{phrase}}</p>
                <span class="mod-playercross-clue-answer">{{#resolved}}&#10003; {{/resolved}}{{revealword}}</span>
            </li>
        {{/clues}}
    </ul>
    {{#showgradesofar}}
        <p class="mt-2 text-center">{{gradesofarmessage}}</p>
    {{/showgradesofar}}
    {{#huditemrewardedlabel}}
        <p class="mt-2 text-center">{{huditemrewardedlabel}}</p>
    {{/huditemrewardedlabel}}
    {{#roundsplayedlabel}}
        <p class="text-muted small mt-1 text-center">{{roundsplayedlabel}}</p>
    {{/roundsplayedlabel}}
    {{#cooldowntext}}
        <p class="text-muted mt-2 text-center">
            {{cooldowncountdownlabel}}
            <strong>
                <span id="playercross-cooldown-countdown">{{cooldowntext}}</span>
            </strong>
        </p>
    {{/cooldowntext}}
    {{^cooldownactive}}
    <div class="text-center">
        <button type="button" id="playercross-new-round-button" class="btn btn-secondary mt-2">{{newroundlabel}}</button>
    </div>
    {{/cooldownactive}}
</div>
