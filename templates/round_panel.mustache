{{!
    @template mod_playercross/round_panel

    Active-round panel: mystery phrase tiles and clue progress, followed by either
    the clue/final-guess forms (mod_playercross/round_play) or the post-round result
    (mod_playercross/round_result), depending on whether the round has finished.

    Example context (json):
    {
        "themetiles": [
            {"letter": "E", "revealed": true, "arialabel": "E, revealed"},
            {"letter": "", "revealed": false, "arialabel": "Hidden letter"}
        ],
        "themelabel": "Mystery phrase",
        "cluesprogresslabel": "0 of 5 clues resolved",
        "clues": [
            {
                "clueid": 12,
                "resolved": false,
                "exhausted": false,
                "attemptsused": 0,
                "wordlength": 4,
                "revealword": "",
                "canguess": true,
                "showhint": false,
                "hintvalue": "",
                "canhint": true,
                "hudhintcost": false,
                "hudhintcostlabel": "",
                "canaffordhint": true
            }
        ],
        "cluelabel": "Clue",
        "guesslabel": "Your guess",
        "guessplaceholder": "Type a word",
        "submitclueguess": "Submit",
        "hintbuttonlabel": "Hint",
        "canfinalguess": true,
        "finalguesslabel": "Mystery phrase",
        "finalguessplaceholder": "Type the mystery phrase",
        "submitfinalguess": "Guess the mystery phrase",
        "roundfinished": false,
        "feedbackmessage": "",
        "revealthemeword": "",
        "revealthemewordlabel": "The mystery phrase was:",
        "scoreachieved": "",
        "scoreachievedlabel": "Score achieved:",
        "cooldowntext": "",
        "cooldowncountdownlabel": "Next round in",
        "cooldownactive": false,
        "newroundlabel": "Start a new round",
        "showgradesofar": false,
        "gradesofarmessage": "",
        "roundsplayedlabel": "",
        "huditemrewardedlabel": ""
    }
}}
<div id="playercross-round-panel">
    <div class="mod-playercross-theme mb-2" role="img" aria-label="{{themelabel}}">
        {{#themetiles}}
            <span class="mod-playercross-tile{{#revealed}} is-revealed{{/revealed}}" aria-label="{{arialabel}}">{{letter}}</span>
        {{/themetiles}}
    </div>
    <p class="text-muted small text-center mb-3">{{cluesprogresslabel}}</p>

    {{^roundfinished}}
        {{> mod_playercross/round_play}}
    {{/roundfinished}}
    {{#roundfinished}}
        {{> mod_playercross/round_result}}
    {{/roundfinished}}
</div>
