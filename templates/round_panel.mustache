{{!
    @template mod_playercross/round_panel

    Active-round panel: the theme concept's own word (shown openly, as a caption —
    never tiled), its hint as the mystery-phrase tiles below, and clue progress,
    followed by either the clue/final-guess forms (mod_playercross/round_play) or the
    post-round result (mod_playercross/round_result), depending on whether the round
    has finished.

    Example context (json):
    {
        "themeconceptlabel": "Concept",
        "themeconcept": "Administração",
        "themetiles": [
            {
                "tiles": [
                    {"letter": "Á", "revealed": true, "slotnum": "", "arialabel": "Á, revealed"},
                    {"letter": "", "revealed": false, "slotnum": "4", "arialabel": "Hidden letter, slot 4"}
                ]
            },
            {
                "tiles": [
                    {"letter": "D", "revealed": true, "slotnum": "", "arialabel": "D, revealed"},
                    {"letter": "E", "revealed": true, "slotnum": "", "arialabel": "E, revealed"}
                ]
            }
        ],
        "themelabel": "Mystery phrase",
        "showglobalhint": true,
        "globalhintlabel": "Hint",
        "showhintsremaining": true,
        "hintsremainingvalue": "3",
        "hintsremaininglabel": "Hints left: 3",
        "hudhintcost": true,
        "hudhintcostlabel": "You have 3× Gold Key. Costs 1×.",
        "canaffordhint": true,
        "cluesprogresslabel": "0 of 5 clues resolved",
        "clues": [
            {
                "clueid": 12,
                "phrase": "A place to keep notes and school exercises",
                "resolved": false,
                "exhausted": false,
                "attemptsused": 0,
                "revealword": "",
                "tiles": [
                    {"letter": "", "revealed": false, "slotnum": "3", "arialabel": "Hidden letter, slot 3"}
                ],
                "canguess": true
            }
        ],
        "guesslabel": "Your answer",
        "submitclueguess": "Submit",
        "canfinalguess": true,
        "submitfinalguess": "Guess the mystery phrase",
        "keyboardlabel": "Virtual keyboard",
        "keyboardenterlabel": "Submit",
        "keyboardentertext": "Send",
        "keyboardbackspacelabel": "Delete last letter",
        "showcedilla": false,
        "roundfinished": false,
        "feedbackmessage": "",
        "revealthemeword": "",
        "revealthemewordlabel": "The mystery phrase was:",
        "scoreachieved": "",
        "scoreachievedlabel": "Score achieved:",
        "cooldowntext": "",
        "cooldowncountdownlabel": "Next round in",
        "cooldownactive": false,
        "newroundlabel": "Start a new round",
        "showgradesofar": false,
        "gradesofarmessage": "",
        "roundsplayedlabel": "",
        "huditemrewardedlabel": ""
    }
}}
<div id="playercross-round-panel">
    <div class="mod-playercross-concept text-center">
        <div class="mod-playercross-concept-eyebrow">{{themeconceptlabel}}</div>
        <div class="mod-playercross-concept-word">{{themeconcept}}</div>
    </div>
    <form id="playercross-final-guess-form" class="mod-playercross-theme-form mod-playercross-guess-form mb-2">
        <p class="fw-bold d-block text-center mb-1">{{themelabel}}</p>
        <div class="mod-playercross-theme" {{#canfinalguess}}role="group" aria-label="{{themelabel}}"{{/canfinalguess}}>
            {{#themetiles}}
                <div class="mod-playercross-word-group">
                    {{#tiles}}
                        <div class="mod-playercross-tile-wrap small">
                            {{#revealed}}
                                <span class="mod-playercross-tile is-revealed"
                                      aria-label="{{arialabel}}">{{letter}}</span>
                            {{/revealed}}
                            {{^revealed}}
                                <input type="text"
                                       class="mod-playercross-tile mod-playercross-tile-input"
                                       inputmode="none"
                                       autocomplete="off"
                                       maxlength="1"
                                       aria-label="{{arialabel}}"
                                       required>
                            {{/revealed}}
                            <span class="mod-playercross-tile-num">{{slotnum}}</span>
                        </div>
                    {{/tiles}}
                </div>
            {{/themetiles}}
        </div>
        {{#canfinalguess}}
            <button type="submit" class="visually-hidden">{{submitfinalguess}}</button>
        {{/canfinalguess}}
    </form>

    {{#showglobalhint}}
        <div class="text-center mb-2">
            <button type="button"
                    id="playercross-global-hint-button"
                    class="mod-playercross-hint-btn"
                    {{#showhintsremaining}}
                        aria-label="{{globalhintlabel}} — {{hintsremaininglabel}}"
                    {{/showhintsremaining}}
                    {{#hudhintcost}}
                        title="{{hudhintcostlabel}}"
                        data-hud-confirm-title="{{globalhintlabel}}"
                        data-hud-confirm-body="{{hudhintcostlabel}}"
                        {{^canaffordhint}}data-hud-confirm-insufficient="1"{{/canaffordhint}}
                    {{/hudhintcost}}>
                <i class="fa fa-lightbulb" aria-hidden="true"></i> {{globalhintlabel}}
                {{#showhintsremaining}}
                    <span class="mod-playercross-hint-count" aria-hidden="true">×{{hintsremainingvalue}}</span>
                {{/showhintsremaining}}
            </button>
        </div>
    {{/showglobalhint}}

    <p class="text-muted small text-center mb-3">{{cluesprogresslabel}}</p>

    {{^roundfinished}}
        {{> mod_playercross/round_play}}
    {{/roundfinished}}
    {{#roundfinished}}
        {{> mod_playercross/round_result}}
    {{/roundfinished}}
</div>
