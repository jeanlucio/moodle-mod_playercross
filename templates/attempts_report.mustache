{{!
    @template mod_playercross/attempts_report

    All-students round history report for a PlayerCross activity, shown only to
    whoever can manage the activity (mod/playercross:addinstance). Paginated,
    sortable, filterable by student.

    Example context (json):
    {
        "activityurl": "https://example.com/mod/playercross/view.php?id=1",
        "backlabel": "Back to game",
        "cmid": 1,
        "reporttitle": "Attempt history — All students",
        "emptylabel": "No student has finished a round yet.",
        "finalguessedlabel": "Direct guess",
        "yeslabel": "Yes",
        "nolabel": "No",
        "isempty": false,
        "filterlabel": "Student",
        "filterbuttonlabel": "Filter",
        "filterurl": "https://example.com/mod/playercross/attemptsreport.php",
        "currentsort": "date",
        "currentdir": "DESC",
        "studentoptions": [
            {"id": 0, "name": "All students", "selected": true},
            {"id": 3, "name": "Ana Silva", "selected": false}
        ],
        "columns": [
            {"key": "student", "label": "Student", "alignend": false, "url": "https://example.com/mod/playercross/attemptsreport.php?sort=student", "active": false, "arrow": ""},
            {"key": "theme", "label": "Mystery phrase", "alignend": false, "url": "https://example.com/mod/playercross/attemptsreport.php?sort=theme", "active": false, "arrow": ""},
            {"key": "clues", "label": "Clues", "alignend": true, "url": "https://example.com/mod/playercross/attemptsreport.php?sort=clues", "active": false, "arrow": ""},
            {"key": "attempts", "label": "Attempts", "alignend": true, "url": "https://example.com/mod/playercross/attemptsreport.php?sort=attempts", "active": false, "arrow": ""},
            {"key": "time", "label": "Time", "alignend": true, "url": "https://example.com/mod/playercross/attemptsreport.php?sort=time", "active": false, "arrow": ""},
            {"key": "score", "label": "Score", "alignend": true, "url": "https://example.com/mod/playercross/attemptsreport.php?sort=score", "active": false, "arrow": ""},
            {"key": "date", "label": "Date", "alignend": false, "url": "https://example.com/mod/playercross/attemptsreport.php?sort=date", "active": true, "arrow": " ▼"}
        ],
        "rows": [
            {
                "student": "Ana Silva",
                "themeword": "Escola",
                "cluesresolved": 3,
                "cluestotal": 3,
                "finalguessed": false,
                "attemptsused": 5,
                "timeused": "1:24",
                "won": true,
                "score": "85.00",
                "datecreated": "14 July 2026, 9:00 AM"
            }
        ],
        "pagingbar": ""
    }
}}
<div class="mod-playercross-attemptsreport-page">
    <p>
        <a href="{{activityurl}}" class="btn btn-secondary btn-sm">{{backlabel}}</a>
    </p>
    <h2>{{reporttitle}}</h2>

    <form method="get" action="{{filterurl}}" class="row g-2 align-items-end mb-3">
        <input type="hidden" name="id" value="{{cmid}}">
        <input type="hidden" name="sort" value="{{currentsort}}">
        <input type="hidden" name="dir" value="{{currentdir}}">
        <div class="col-auto">
            <label for="playercross-filter-student" class="form-label">{{filterlabel}}</label>
            <select name="studentid" id="playercross-filter-student" class="form-select">
                {{#studentoptions}}
                    <option value="{{id}}" {{#selected}}selected{{/selected}}>{{name}}</option>
                {{/studentoptions}}
            </select>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-secondary">{{filterbuttonlabel}}</button>
        </div>
    </form>

    {{#isempty}}
        <p class="text-muted">{{emptylabel}}</p>
    {{/isempty}}
    {{^isempty}}
        <div class="table-responsive">
            <table class="table table-sm mod-playercross-myattempts-table">
                <thead>
                    <tr>
                        {{#columns}}
                            <th scope="col" {{#alignend}}class="text-end"{{/alignend}}>
                                <a href="{{url}}">{{label}}{{arrow}}</a>
                            </th>
                        {{/columns}}
                    </tr>
                </thead>
                <tbody>
                    {{#rows}}
                        <tr>
                            <td>{{student}}</td>
                            <td>{{themeword}}</td>
                            <td class="text-end">{{cluesresolved}}/{{cluestotal}}</td>
                            <td class="text-end">{{attemptsused}}</td>
                            <td class="text-end">{{timeused}}</td>
                            <td class="text-end">{{score}}</td>
                            <td>{{datecreated}}</td>
                        </tr>
                    {{/rows}}
                </tbody>
            </table>
        </div>
        {{{pagingbar}}}
    {{/isempty}}
</div>
