<div class="mod-playercross-game">
    <div class="pc-header">
        <div class="pc-toolbar">
            <button type="button" id="playercross-help-button" class="btn btn-link p-0" data-title="{{helptitle}}">
                <i class="fa fa-question-circle" aria-hidden="true"></i> {{helptitle}}
            </button>
            <a href="{{myattemptsurl}}" class="btn btn-link p-0">{{toolbarmyattempts}}</a>
            {{#showranking}}
                <a href="{{rankingurl}}" class="btn btn-link p-0">{{toolbarranking}}</a>
            {{/showranking}}
            {{#canmanage}}
                <a href="{{managewordsurl}}" class="btn btn-link p-0">{{toolbarmanagewords}}</a>
                <a href="{{attemptsreporturl}}" class="btn btn-link p-0">{{toolbarreport}}</a>
            {{/canmanage}}
            {{#showforfeit}}
                <button type="button"
                        id="playercross-forfeit-button"
                        class="btn btn-link p-0 text-danger"
                        data-title="{{forfeitlabel}}"
                        data-confirm="{{forfeitconfirm}}">
                    {{forfeitlabel}}
                </button>
            {{/showforfeit}}
        </div>
        {{#timerenabled}}
            <span id="playercross-timer-wrapper" class="pc-header-timer"
                {{#showlobby}}hidden{{/showlobby}}
                {{#roundfinished}}hidden{{/roundfinished}}>
                <i class="fa fa-clock-o" aria-hidden="true"></i>
                <span id="playercross-timer-countdown" aria-label="{{timerlabel}}">{{timeleft}}</span>
            </span>
        {{/timerenabled}}
    </div>

    {{^hastheme}}
        <div class="alert alert-warning">{{nogamewords}}</div>
    {{/hastheme}}

    {{#hastheme}}
        <div id="playercross-stage">
            {{#showlobby}}
                {{> mod_playercross/lobby}}
            {{/showlobby}}
            {{^showlobby}}
                {{> mod_playercross/round_panel}}
            {{/showlobby}}
        </div>
    {{/hastheme}}

    {{#showwordsstatus}}
        {{#hasinactivewords}}
            {{> mod_playercross/inactive_words}}
        {{/hasinactivewords}}
        {{^hasinactivewords}}
            <p class="mod-playercross-words-status text-muted small mb-2">{{activewordscount}}</p>
        {{/hasinactivewords}}
    {{/showwordsstatus}}

    <div id="playercross-live-region"
         class="visually-hidden"
         aria-live="polite"
         aria-atomic="true"></div>

    <div id="playercross-help-content" hidden>
        {{> mod_playercross/help_body}}
    </div>
</div>
