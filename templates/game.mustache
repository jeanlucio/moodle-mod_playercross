<div class="mod-playercross-game">
    <div class="pc-header">
        {{> mod_playercross/toolbar}}
        {{#timerenabled}}
            <span id="playercross-timer-wrapper" class="pc-header-timer"
                {{#showlobby}}hidden{{/showlobby}}
                {{#roundfinished}}hidden{{/roundfinished}}>
                <i class="fa fa-clock-o" aria-hidden="true"></i>
                <span id="playercross-timer-countdown" aria-label="{{timerlabel}}">{{timeleft}}</span>
            </span>
        {{/timerenabled}}
    </div>

    {{!
        Rendered above the game area, not below it: the on-screen keyboard inside
        #playercross-stage is position: fixed to the viewport's bottom edge on mobile,
        with no reserved space of its own for content that comes after it in the
        document — anything placed below the stage risks sitting behind the keyboard,
        mostly hidden, with only a sliver of descenders (e.g. "jogo"'s j/g) peeking out.
    }}
    {{#showwordsstatus}}
        {{#hasinactivewords}}
            {{> mod_playercross/inactive_words}}
        {{/hasinactivewords}}
        {{^hasinactivewords}}
            <p class="mod-playercross-words-status text-muted small mb-2">{{activewordscount}}</p>
        {{/hasinactivewords}}
    {{/showwordsstatus}}

    {{^hastheme}}
        <div class="alert alert-warning">{{nogamewords}}</div>
    {{/hastheme}}

    {{#hastheme}}
        <div id="playercross-stage">
            {{#showlobby}}
                {{> mod_playercross/lobby}}
            {{/showlobby}}
            {{^showlobby}}
                {{> mod_playercross/round_panel}}
            {{/showlobby}}
        </div>
    {{/hastheme}}

    <div id="playercross-live-region"
         class="visually-hidden"
         aria-live="polite"
         aria-atomic="true"></div>

    <div id="playercross-help-content" hidden>
        {{> mod_playercross/help_body}}
    </div>
</div>
